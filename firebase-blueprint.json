{
  "entities": {
    "ItineraryCache": {
      "title": "ItineraryCache",
      "description": "A cached itinerary generated by Gemini.",
      "type": "object",
      "properties": {
        "destination": {
          "type": "string",
          "description": "The requested destination."
        },
        "budget": {
          "type": "string",
          "description": "The requested budget."
        },
        "interests": {
          "type": "array",
          "items": { "type": "string" },
          "description": "The requested interests."
        },
        "tone": {
          "type": "number",
          "description": "The requested tone."
        },
        "result": {
          "type": "string",
          "description": "The JSON stringified GenerationResult."
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the cache entry was created."
        }
      },
      "required": ["destination", "budget", "interests", "tone", "result", "createdAt"]
    }
  },
  "firestore": {
    "/itineraries/{itineraryId}": {
      "schema": "ItineraryCache",
      "description": "Cached itineraries."
    }
  }
}
